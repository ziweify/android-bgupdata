<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_about"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="使用说明"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 后台运行说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="保持后台运行（重要）"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_stopped" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="部分手机品牌有后台管理限制，需手动设置以保证锁屏/黑屏时任务不中断："
                        android:textSize="14sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="【小米 / Redmi】"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1. 设置 → 应用设置 → 应用管理 → 找到本应用 → 省电策略 → 选择\"无限制\"\n2. 设置 → 电池与性能 → 找到本应用 → 关闭\"后台限制\"\n3. 最近任务列表 → 下拉本应用卡片锁定"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="【华为 / 荣耀】"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1. 设置 → 电池 → 启动管理 → 找到本应用 → 关闭自动管理 → 手动开启全部开关\n2. 设置 → 应用和服务 → 应用启动管理 → 允许自启动、关联启动、后台活动\n3. 最近任务列表 → 下拉本应用卡片锁定"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="【OPPO / realme】"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1. 设置 → 电池 → 更多电池设置 → 关闭\"休眠时关闭后台\"\n2. 设置 → 应用管理 → 找到本应用 → 耗电保护 → 允许后台运行\n3. 最近任务列表 → 下拉本应用卡片锁定"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="【VIVO / iQOO】"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1. 设置 → 电池 → 后台高耗电 → 允许本应用\n2. 设置 → 应用与权限 → 自启动管理 → 允许本应用自启动\n3. 最近任务列表 → 下拉本应用卡片锁定"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="【三星】"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1. 设置 → 电池和设备维护 → 电池 → 后台使用限制 → 将本应用从\"深度休眠\"移除\n2. 设置 → 应用程序 → 找到本应用 → 电池 → 不受限"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 通用说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="通用建议"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 启动任务后，通知栏会常驻\"采集任务运行中\"通知，请勿手动清除\n\n• 在最近任务列表中锁定本应用（下拉应用卡片出现锁图标），防止被一键清理\n\n• 如果手机有\"省电模式\"或\"超级省电\"，请关闭或将本应用加入白名单\n\n• 确保手机网络正常连接（WiFi 或移动数据）"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 功能说明 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="功能说明"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 投递地址：支持添加多个投递地址，每个地址可选择类型（wold/w168/boter/netboter），可单独启用或禁用\n\n• 自动采集：启动任务后，程序会自动计算开奖倒计时，到时间自动采集数据\n\n• 自动投递：采集到数据后，自动向所有启用的地址投递（失败自动重试3次）\n\n• 采集失败：如果某期超过10期仍未采集到，将标记为失败并停止该期采集"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
